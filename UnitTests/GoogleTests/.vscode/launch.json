{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CoreLibraryUnitTests (single gtest)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/Debug/CoreLibraryUnitTests.exe",
      "args": [
        "--gtest_filter=AsioTest.testCase_TestTypedAsync",
        "--gtest_break_on_failure",
        "--gtest_catch_exceptions=0"
      ],
      "cwd": "${workspaceFolder}/build/Debug",
      "environment": [
        { "name": "CORELIB_BOOST_ROOT", "value": "${workspaceFolder}/../../../ThirdParty/boost_1_90_0" },
        { "name": "CORELIB_BOOST_LIB", "value": "${workspaceFolder}/../../../ThirdParty/boost_1_90_0/lib64-msvc-14.3" },
        { "name": "CORELIB_BOOST_LIB_NAME_STUB", "value": "vc143-mt-x64-1_90" },
        { "name": "CORELIB_BOOST_LIB_NAME_STUB_D", "value": "vc143-mt-gd-x64-1_90" }
      ],
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ]
}